# === Firebase Admin SDK (server-side, from Firebase Console > Project Settings > Service Accounts) ===
FIREBASE_ADMIN_PROJECT_ID=donordrop-xxxxx
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@donordrop-xxxxx.iam.gserviceaccount.com
# IMPORTANT: paste the private key as ONE line with literal \n sequences —
# lib/firebase-admin.ts un-escapes them at runtime. Do not paste actual
# newlines here.
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# === Firebase Client SDK (public, safe to expose - used only by the admin login page) ===
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=donordrop-xxxxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=donordrop-xxxxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=donordrop-xxxxx.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Cloudinary ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
