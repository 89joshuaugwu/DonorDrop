rules_version = '2';

// DonorDrop Firestore Rules
// -----------------------------------------------------------------------
// PASTE THIS INTO: Firebase Console -> Firestore Database -> Rules -> Publish
// This is a MANUAL step. It cannot be automated/deployed from code in
// this handoff — you must paste and click Publish yourself.
// -----------------------------------------------------------------------
//
// Privacy note: donor phone numbers are protected at TWO layers, not one:
//   1. This rule blocks any client (other than the donor themself or an
//      admin) from reading a donor's phone/name fields directly.
//   2. The bulk "nearby donors" matching query runs server-side via
//      firebase-admin (which bypasses these rules entirely) and only
//      returns lat/lng/bloodType/geohash/isVisible to the matching logic
//      — it never selects or returns phone/name to any client.
// Both layers matter. If a panel member asks "how is donor privacy
// protected," the honest answer cites both.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // --- Donors ---
    // Any signed-in user CAN read a donor doc (needed for the requester's
    // client-side compatibility/distance display in some flows), but the
    // canonical nearby-donor MATCHING query is done server-side via
    // firebase-admin (bloodpadi-admin's /api/requests/notify-matches),
    // which bypasses these rules anyway. Writes are locked to the owner
    // or an admin (for the `verified` flag).
    match /donors/{donorId} {
      allow read: if isSignedIn();
      allow create: if isOwner(donorId);
      allow update: if isOwner(donorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Requesters ---
    // Same ownership pattern as donors: a signed-in user can read any
    // requester profile (needed for donor-side display of who posted a
    // request) but can only create/update their OWN doc.
    match /requesters/{requesterId} {
      allow read: if isSignedIn();
      allow create: if isOwner(requesterId);
      allow update: if isOwner(requesterId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Requests ---
    match /requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.requesterUid == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.requesterUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      // --- Responses subcollection ---
      // A donor can create their OWN response doc. Only the requester who
      // owns the parent request, or an admin, can read the full responses
      // list (which contains donor phone numbers for "available" donors).
      // This is the core privacy enforcement point for "requester can't
      // see donor phone until donor taps Available" — it's enforced here,
      // not just by hiding it in the UI.
      match /responses/{donorId} {
        allow create: if isOwner(donorId);
        allow update: if isOwner(donorId);
        allow read: if isOwner(donorId) ||
          isAdmin() ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.requesterUid == request.auth.uid;
      }
    }

    // --- Donations ---
    match /donations/{donationId} {
      allow read: if isSignedIn() &&
        (resource.data.donorUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.donorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Notifications ---
    // Each user only ever reads their OWN notification items. Written
    // server-side only (firebase-admin, via notifyMatchingDonors()) — no
    // client write rule needed since the admin SDK bypasses rules.
    match /notifications/{uid}/items/{itemId} {
      allow read, update: if isOwner(uid);
      allow write: if false; // server-side only, via firebase-admin
    }
  }
}
